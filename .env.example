# Path to your markdown docs directory (the folder recall will index)
# Default if not set: ~/docs
DOCS_PATH=/Users/yourname/path/to/your/docs

# Ollama URL (default: http://localhost:11434)
# Only change this if you're running Ollama on a non-standard port
# OLLAMA_URL=http://localhost:11434

# Embedding model (default: nomic-embed-text)
# Only change if you want to use a different Ollama model
# EMBEDDING_MODEL=nomic-embed-text
